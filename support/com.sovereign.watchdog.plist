<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sovereign.watchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>WATCHDOG_SCRIPT_PLACEHOLDER</string>
    </array>
    <key>WorkingDirectory</key>
    <string>REPO_DIR_PLACEHOLDER</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>SOVEREIGN_CONFIG_DIR</key>
        <string>CONFIG_DIR_PLACEHOLDER</string>
        <key>SOVEREIGN_DATA_DIR</key>
        <string>DATA_DIR_PLACEHOLDER</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>StartInterval</key>
    <integer>60</integer>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>WATCHDOG_LOG_PLACEHOLDER</string>
    <key>StandardErrorPath</key>
    <string>WATCHDOG_LOG_PLACEHOLDER</string>
</dict>
</plist>
