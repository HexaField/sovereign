#!/usr/bin/env bash
#
# Sovereign service CLI — guarded builds, launchd lifecycle, health checks, and logs.
#
# Usage:
#   sovereign install            Install/update the launchd plist
#   sovereign start              Start the service
#   sovereign stop               Stop the service
#   sovereign restart            Restart the service and verify health
#   sovereign reload             Alias for restart
#   sovereign status             Show launchd + health status
#   sovereign build              Run guarded check/build; reload if running
#   sovereign health             Query HTTP health endpoint
#   sovereign logs [stdout|stderr|all]
#   sovereign run                Run in foreground (no daemon)
#
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SERVER_ENTRY="$REPO_DIR/packages/server/dist/index.js"
PLIST_LABEL="com.sovereign.server"
LAUNCH_DOMAIN="gui/$(id -u)"
LAUNCH_TARGET="$LAUNCH_DOMAIN/$PLIST_LABEL"
PLIST_DEST="$HOME/Library/LaunchAgents/${PLIST_LABEL}.plist"
PLIST_TEMPLATE="$REPO_DIR/support/com.sovereign.server.plist"
LAUNCH_SCRIPT="$REPO_DIR/bin/sovereign-launchd.sh"
TMP_ROOT="${TMPDIR:-/tmp}"

# Sovereign separates *config* from *data*:
#   SOVEREIGN_CONFIG_DIR  — user-edited state (just config.json today).
#                           Defaults to ~/.sovereign. Intended to be
#                           version-controlled.
#   SOVEREIGN_DATA_DIR    — runtime state (threads, queues, logs, scheduler,
#                           secrets.json, config-history.jsonl). Defaults to
#                           ${SOVEREIGN_CONFIG_DIR}/data. Should be gitignored.
# Everything else (HOST/PORT/TLS/...) lives in config.json — env vars are not
# consulted for those.

_read_config_json() {
  # _read_config_json <dot.path> <default>
  local dotpath="$1"
  local default="$2"
  local config="$CONFIG_DIR/config.json"
  if [ ! -f "$config" ] || ! command -v node >/dev/null 2>&1; then
    printf '%s' "$default"
    return
  fi
  node -e '
    try {
      const c = JSON.parse(require("fs").readFileSync(process.argv[1], "utf-8"));
      const parts = process.argv[2].split(".");
      let v = c;
      for (const p of parts) v = v && typeof v === "object" ? v[p] : undefined;
      if (v === undefined || v === null || v === "") process.stdout.write(process.argv[3]);
      else process.stdout.write(String(v));
    } catch { process.stdout.write(process.argv[3]); }
  ' "$config" "$dotpath" "$default" 2>/dev/null || printf '%s' "$default"
}

_config_check() {
  # Validate a config.json against the live schema. Prints offending paths to
  # stderr. Returns 0 valid, 1 invalid, 2 unreadable. Skips (returns 0) when
  # node or the built validator is unavailable, so it never blocks on its own.
  local target="${1:-$CONFIG_DIR/config.json}"
  local mod="$REPO_DIR/packages/config/dist/index.js"
  if ! command -v node >/dev/null 2>&1; then
    _warn "node not found — skipping validation of $target"
    return 0
  fi
  if [ ! -f "$mod" ]; then
    _warn "config validator not built ($mod missing) — run 'sovereign build'; skipping validation"
    return 0
  fi
  if [ ! -f "$target" ]; then
    _warn "no config at $target — nothing to validate"
    return 0
  fi
  node --input-type=module -e '
    import { readFileSync } from "node:fs"
    import { pathToFileURL } from "node:url"
    const [mod, target] = process.argv.slice(1)
    const { validate } = await import(pathToFileURL(mod).href)
    let cfg
    try { cfg = JSON.parse(readFileSync(target, "utf-8")) }
    catch (e) { console.error("  cannot read/parse: " + e.message); process.exit(2) }
    const { valid, errors } = validate(cfg)
    if (valid) process.exit(0)
    for (const e of errors) console.error("  " + e)
    process.exit(1)
  ' "$mod" "$target"
}

CONFIG_DIR="${SOVEREIGN_CONFIG_DIR:-$HOME/.sovereign}"
DATA_DIR="${SOVEREIGN_DATA_DIR:-$CONFIG_DIR/data}"
LOG_DIR="$DATA_DIR/logs"
STDOUT_LOG="$LOG_DIR/sovereign.stdout.log"
STDERR_LOG="$LOG_DIR/sovereign.stderr.log"
PID_FILE="$DATA_DIR/sovereign.pid"
HOST_VALUE="$(_read_config_json server.host 127.0.0.1)"
PORT_VALUE="$(_read_config_json server.port 5801)"
TLS_VALUE="$(_read_config_json server.tls.enabled false)"
HEALTH_SCHEME="http"
if [ "$TLS_VALUE" = "true" ]; then
  HEALTH_SCHEME="https"
fi
HEALTH_URL="${HEALTH_SCHEME}://127.0.0.1:${PORT_VALUE}/health"

mkdir -p "$DATA_DIR" "$LOG_DIR"

_note() { printf '==> %s\n' "$*"; }
_warn() { printf 'WARN: %s\n' "$*" >&2; }
_die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

_is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

_launchctl_print() {
  launchctl print "$LAUNCH_TARGET" 2>/dev/null
}

_is_launchd_loaded() {
  launchctl list | awk '{print $3}' | grep -Fxq "$PLIST_LABEL"
}

_is_running() {
  if _is_macos; then
    _is_launchd_loaded
  else
    [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
  fi
}

_service_pid() {
  if _is_macos; then
    _launchctl_print | awk '/pid = / { print $3; exit }'
  elif [ -f "$PID_FILE" ]; then
    cat "$PID_FILE"
  fi
}

_healthcheck() {
  local out
  if out=$(curl --silent --show-error --fail --max-time 2 --insecure "$HEALTH_URL" 2>/dev/null); then
    printf '%s\n' "$out"
    return 0
  fi
  return 1
}

# ── Active-agent notice ─────────────────────────────────────────────────────
# Sovereign snapshots active threads to disk continuously (active-sessions.json)
# and auto-resumes them on restart, so destructive lifecycle commands no longer
# need to refuse when sessions are working. We still report what's about to be
# snapshotted so the operator knows what'll resume. Fail-open: if the API is
# unreachable, just skip the notice.
AGENTS_URL="${HEALTH_SCHEME}://127.0.0.1:${PORT_VALUE}/api/system/agents/active"

_active_agents_json() {
  curl --silent --show-error --fail --max-time 3 --insecure "$AGENTS_URL" 2>/dev/null
}

_active_agents_count() {
  local json
  json="$(_active_agents_json)" || { printf '0'; return 0; }
  [ -n "$json" ] || { printf '0'; return 0; }
  if command -v node >/dev/null 2>&1; then
    printf '%s' "$json" | node -e 'let s="";process.stdin.on("data",d=>s+=d).on("end",()=>{try{process.stdout.write(String(JSON.parse(s).count||0))}catch{process.stdout.write("0")}})' 2>/dev/null || printf '0'
  else
    printf '%s' "$json" | grep -oE '"count":[0-9]+' | head -1 | sed 's/"count"://' || printf '0'
  fi
}

# Print a one-line notice when a destructive action is about to fire against a
# server with non-idle sessions. Caller passes the action name. --force is
# tolerated as a no-op (R16) so muscle memory and scripts don't break.
_notice_active_agents() {
  local action="$1"
  if ! _is_running; then
    return 0
  fi
  local count
  count="$(_active_agents_count)"
  count="${count:-0}"
  if ! [[ "$count" =~ ^[0-9]+$ ]]; then
    count=0
  fi
  if [ "$count" = "0" ]; then
    return 0
  fi
  _note "$count active session(s) — will snapshot and resume on next start."
}

_wait_for_health() {
  local timeout_secs="${1:-20}"
  local attempt=1
  local max_attempts=$((timeout_secs * 2))
  while [ "$attempt" -le "$max_attempts" ]; do
    if _healthcheck >/dev/null; then
      return 0
    fi
    sleep 0.5
    attempt=$((attempt + 1))
  done
  return 1
}

_install_plist() {
  mkdir -p "$(dirname "$PLIST_DEST")"
  sed -e "s|REPO_DIR_PLACEHOLDER|${REPO_DIR}|g" \
      -e "s|LAUNCH_SCRIPT_PLACEHOLDER|${LAUNCH_SCRIPT}|g" \
      -e "s|STDOUT_LOG_PLACEHOLDER|${STDOUT_LOG}|g" \
      -e "s|STDERR_LOG_PLACEHOLDER|${STDERR_LOG}|g" \
      -e "s|CONFIG_DIR_PLACEHOLDER|${CONFIG_DIR}|g" \
      -e "s|DATA_DIR_PLACEHOLDER|${DATA_DIR}|g" \
      "$PLIST_TEMPLATE" > "$PLIST_DEST"
}

_bootstrap_service() {
  launchctl bootstrap "$LAUNCH_DOMAIN" "$PLIST_DEST"
}

_bootout_service() {
  if _is_launchd_loaded; then
    launchctl bootout "$LAUNCH_TARGET" >/dev/null 2>&1 || launchctl bootout "$LAUNCH_DOMAIN" "$PLIST_DEST" >/dev/null 2>&1 || true
  fi
}

_kickstart_service() {
  launchctl kickstart -k "$LAUNCH_TARGET"
}

_start_launchd_service() {
  [ -f "$SERVER_ENTRY" ] || _die "Server not built. Run: sovereign build"
  _install_plist
  if _is_launchd_loaded; then
    _note "Service already loaded; verifying health"
    if ! _wait_for_health 5; then
      _warn "Loaded service is not healthy; kickstarting it"
      _kickstart_service
    fi
  else
    _note "Starting Sovereign via launchd"
    _bootstrap_service
  fi
  if _wait_for_health 20; then
    _note "Sovereign healthy at $HEALTH_URL"
  else
    tail -n 40 "$STDERR_LOG" 2>/dev/null || true
    _warn "Service failed health verification after start"
    return 1
  fi
}

_stop_launchd_service() {
  if _is_launchd_loaded; then
    _note "Stopping Sovereign launchd service"
    _bootout_service
  else
    _note "Service not loaded"
  fi
}

_restart_launchd_service() {
  [ -f "$SERVER_ENTRY" ] || _die "Server not built. Run: sovereign build"
  _install_plist
  if _is_launchd_loaded; then
    _note "Restarting Sovereign via launchd kickstart"
    _kickstart_service
  else
    _note "Service not loaded; bootstrapping"
    _bootstrap_service
  fi
  if _wait_for_health 20; then
    _note "Sovereign healthy at $HEALTH_URL"
  else
    tail -n 60 "$STDERR_LOG" 2>/dev/null || true
    _warn "Service failed health verification after restart"
    return 1
  fi
}

_start_non_macos() {
  if _is_running; then
    _die "Already running"
  fi
  [ -f "$SERVER_ENTRY" ] || _die "Server not built. Run: sovereign build"
  _note "Starting Sovereign"
  cd "$REPO_DIR"
  nohup node "$SERVER_ENTRY" >>"$STDOUT_LOG" 2>>"$STDERR_LOG" &
  local pid=$!
  echo "$pid" > "$PID_FILE"
  disown "$pid" 2>/dev/null || true
  if _wait_for_health 20; then
    _note "Sovereign healthy at $HEALTH_URL"
  else
    _warn "Service failed health verification after start"
    return 1
  fi
}

_stop_non_macos() {
  if ! _is_running; then
    _note "Not running"
    rm -f "$PID_FILE"
    return 0
  fi
  local pid
  pid=$(cat "$PID_FILE")
  _note "Stopping Sovereign (pid $pid)"
  kill "$pid" 2>/dev/null || true
  local i=0
  while kill -0 "$pid" 2>/dev/null && [ $i -lt 50 ]; do
    sleep 0.1
    i=$((i + 1))
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
}

_backup_artifacts() {
  BACKUP_DIR=$(mktemp -d "$TMP_ROOT/sovereign-build-backup.XXXXXX")
  # Snapshot every workspace package that currently has a dist/, so a
  # mid-build failure can be rolled back cleanly. Packages added or freshly
  # built later have no snapshot and are left alone on restore.
  local dist pkg dest
  for dist in "$REPO_DIR"/packages/*/dist; do
    [ -d "$dist" ] || continue
    pkg="$(basename "$(dirname "$dist")")"
    dest="$BACKUP_DIR/$pkg"
    mkdir -p "$dest"
    cp -R "$dist" "$dest/dist"
    touch "$dest/.had_dist"
  done
}

_restore_artifacts() {
  [ -n "${BACKUP_DIR:-}" ] || return 0
  local snapshot pkg src
  for snapshot in "$BACKUP_DIR"/*; do
    [ -d "$snapshot" ] || continue
    pkg="$(basename "$snapshot")"
    src="$REPO_DIR/packages/$pkg/dist"
    if [ -f "$snapshot/.had_dist" ] && [ -d "$snapshot/dist" ]; then
      rm -rf "$src"
      mkdir -p "$(dirname "$src")"
      cp -R "$snapshot/dist" "$src"
    fi
  done
}

_cleanup_backup() {
  if [ -n "${BACKUP_DIR:-}" ] && [ -d "$BACKUP_DIR" ]; then
    rm -rf "$BACKUP_DIR"
  fi
}

_run_checks() {
  _note "Running type checks + lint"
  (cd "$REPO_DIR" && pnpm check)
}

_run_builds() {
  # `pnpm -r --if-present build` walks every workspace package that has a
  # build script in topological order — required after the modularisation
  # refactor where the server now depends on ~25 sibling packages whose
  # `dist/` directories must be present at runtime.
  _note "Building all workspace packages"
  (cd "$REPO_DIR" && pnpm -r --if-present build)
}

_guarded_build() {
  local was_running=0
  if _is_running; then
    was_running=1
  fi

  _run_checks
  _backup_artifacts

  local build_ok=0
  if _run_builds; then
    build_ok=1
  else
    _warn "Build failed; restoring previous build artifacts"
    _restore_artifacts
    _cleanup_backup
    _die "Guarded build failed before reload; running service left untouched"
  fi

  if [ "$build_ok" -eq 1 ] && [ "$was_running" -eq 1 ]; then
    _note "Reloading running service"
    if _is_macos; then
      if _restart_launchd_service; then
        _cleanup_backup
        return 0
      fi
    else
      _stop_non_macos
      if _start_non_macos; then
        _cleanup_backup
        return 0
      fi
    fi

    _warn "Reload failed health verification; restoring previous build artifacts"
    _restore_artifacts
    if _is_macos; then
      _restart_launchd_service || _die "Rollback failed; inspect $STDERR_LOG"
    else
      _stop_non_macos || true
      _start_non_macos || _die "Rollback failed; inspect $STDERR_LOG"
    fi
    _cleanup_backup
    _die "Reload failed; rolled back to last known-good build"
  fi

  _cleanup_backup
  if [ "$was_running" -eq 1 ]; then
    _note "Build + reload complete"
  else
    _note "Build complete; service was not running"
  fi
}

_show_status() {
  echo "Label: $PLIST_LABEL"
  echo "Repo: $REPO_DIR"
  echo "Config: $CONFIG_DIR"
  echo "Data: $DATA_DIR"
  echo "Plist: $PLIST_DEST"
  echo "Stdout: $STDOUT_LOG"
  echo "Stderr: $STDERR_LOG"
  echo "Health: $HEALTH_URL"

  if _is_running; then
    local pid
    pid=$(_service_pid || true)
    echo "State: running"
    if [ -n "$pid" ]; then
      echo "PID: $pid"
    fi
  else
    echo "State: stopped"
  fi

  if _healthcheck >/tmp/sovereign-health.$$ 2>/dev/null; then
    echo "HTTP: healthy"
    cat /tmp/sovereign-health.$$
    rm -f /tmp/sovereign-health.$$
  else
    rm -f /tmp/sovereign-health.$$ 2>/dev/null || true
    echo "HTTP: unavailable"
  fi
}

_tail_logs() {
  local mode="${1:-all}"
  case "$mode" in
    stdout)
      touch "$STDOUT_LOG"
      tail -f "$STDOUT_LOG"
      ;;
    stderr)
      touch "$STDERR_LOG"
      tail -f "$STDERR_LOG"
      ;;
    all)
      touch "$STDOUT_LOG" "$STDERR_LOG"
      tail -f "$STDOUT_LOG" "$STDERR_LOG"
      ;;
    *)
      _die "Unknown logs mode: $mode (use stdout|stderr|all)"
      ;;
  esac
}

case "${1:-help}" in
  install)
    _is_macos || _die "install is only needed on macOS"
    _install_plist
    _note "Installed plist at $PLIST_DEST"
    ;;
  start)
    if _is_macos; then
      _start_launchd_service
    else
      _start_non_macos
    fi
    ;;
  stop)
    _notice_active_agents stop
    if _is_macos; then
      _stop_launchd_service
    else
      _stop_non_macos
    fi
    ;;
  restart|reload)
    _notice_active_agents restart
    if _is_macos; then
      _restart_launchd_service
    else
      _stop_non_macos
      _start_non_macos
    fi
    ;;
  status)
    _show_status
    ;;
  build)
    _notice_active_agents build
    _guarded_build
    ;;
  health)
    if _healthcheck; then
      exit 0
    fi
    exit 1
    ;;
  logs)
    _tail_logs "${2:-all}"
    ;;
  run)
    _note "Running in foreground"
    cd "$REPO_DIR"
    exec node "$SERVER_ENTRY"
    ;;
  config-check)
    target="${2:-$CONFIG_DIR/config.json}"
    if _config_check "$target"; then
      _note "config OK: $target"
    else
      rc=$?
      [ "$rc" -eq 2 ] && _die "could not read $target"
      _die "config failed schema validation: $target (see above)"
    fi
    ;;
  migrate)
    shift
    exec "$REPO_DIR/bin/sovereign-migrate.sh" "$@"
    ;;
  help|--help|-h)
    cat <<EOF
Usage: sovereign <command>

Commands:
  install            Install/update the launchd plist (macOS)
  start              Start the background service
  stop               Stop the background service
  restart            Restart the service and verify health
  reload             Alias for restart
  status             Show launchd + HTTP health state
  build              Guarded check/build; reload only after success
  health             Print /health response
  logs [mode]        Tail logs (stdout|stderr|all)
  run                Run in foreground (no daemon)
  config-check [path] Validate config.json against the live schema
  migrate [flags]    One-shot OpenClaw → Sovereign migration (--dry-run, --yes)

  stop, restart, reload, and build snapshot any non-idle agent sessions to
  active-sessions.json and auto-resume them on next start.

Configuration (lives in {CONFIG_DIR}/config.json; managed via /api/config):
  server.host        Bind address (default: localhost)
  server.port        Server port (default: 3001)
  server.tls.enabled HTTPS toggle (default: true)

Environment (the only bootstrap env vars):
  SOVEREIGN_CONFIG_DIR  User-edited state (default: \$HOME/.sovereign)
                        Holds config.json. Intended to be version-controlled.
  SOVEREIGN_DATA_DIR    Runtime state (default: \$SOVEREIGN_CONFIG_DIR/data)
                        Holds threads, queues, logs, scheduler, secrets.json,
                        config-history.jsonl. Should be gitignored.
EOF
    ;;
  *)
    _die "Unknown command: $1"
    ;;
esac
